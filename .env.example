# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in the browser app.
# Set this in .env.local if you want to enable the AI assistant.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SMTP email sender used by SmartGrid alert service.
# For Gmail, use an app password, not your normal account password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="smartgrid.alerts@example.com"
SMTP_PASS="MY_SMTP_APP_PASSWORD"
SMTP_FROM="smartgrid.alerts@example.com"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret key used to sign and verify JSON Web Tokens for authentication.
# Generate a strong random string for production use.
JWT_SECRET="your_jwt_secret_here"

# DB_PATH: File path to the SQLite database.
# Defaults to ./db/smartgrid.db if not set.
DB_PATH="./db/smartgrid.db"
